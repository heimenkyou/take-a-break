{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "歇会儿",
	"version": "0.1.0",
	"identifier": "cn.luowb.take-a-break",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "popup",
				"url": "/#/popup",
				"width": 240,
				"height": 210,
				"decorations": false,
				"transparent": false,
				"alwaysOnTop": true,
				"skipTaskbar": true,
				"visible": false,
				"resizable": false,
				"focus": false
			},
			{
				"label": "alert",
				"url": "/#/alert",
				"width": 400,
				"height": 520,
				"decorations": false,
				"transparent": false,
				"alwaysOnTop": true,
				"skipTaskbar": false,
				"visible": false,
				"resizable": false,
				"center": true
			},
			{
				"label": "settings",
				"url": "/#/settings",
				"title": "歇会儿 · 设置",
				"width": 680,
				"height": 460,
				"decorations": true,
				"transparent": false,
				"alwaysOnTop": false,
				"skipTaskbar": false,
				"visible": false,
				"resizable": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
